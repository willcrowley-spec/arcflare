# Database
DATABASE_URL=postgresql+asyncpg://arcflare:arcflare@localhost:5432/arcflare
DATABASE_URL_SYNC=postgresql://arcflare:arcflare@localhost:5432/arcflare

# Redis
REDIS_URL=redis://localhost:6379/0

# Clerk Authentication
CLERK_SECRET_KEY=sk_test_xxxx
CLERK_PUBLISHABLE_KEY=pk_test_xxxx

# OpenAI (embeddings)
OPENAI_API_KEY=sk-xxxx

# Anthropic (reasoning/analysis)
ANTHROPIC_API_KEY=sk-ant-xxxx

# Google Gemini (optional alternative provider)
GEMINI_API_KEY=

# LLM Configuration
LLM_PROVIDER=anthropic          # openai, anthropic, or gemini
LLM_LITE_MODEL=                 # cheap/fast model (default: auto per provider)
LLM_FAST_MODEL=                 # balanced model (default: auto per provider)
LLM_STRONG_MODEL=               # most capable model (default: auto per provider)
LLM_RATE_DELAY=0                # seconds between LLM calls (rate limiting)

# Salesforce Connected App
SALESFORCE_CLIENT_ID=your_connected_app_consumer_key
SALESFORCE_CLIENT_SECRET=your_connected_app_consumer_secret
SALESFORCE_REDIRECT_URI=http://localhost:8000/api/v1/connections/salesforce/callback

# Security
ENCRYPTION_KEY=generate-with-python-cryptography-fernet

# Frontend URL (for CORS)
FRONTEND_URL=http://localhost:5173

# Environment
ENVIRONMENT=development
